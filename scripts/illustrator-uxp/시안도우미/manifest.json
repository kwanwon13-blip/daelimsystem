{
  "id": "com.dlsm.designer.helper",
  "name": "시안 도우미",
  "version": "1.0.0",
  "manifestVersion": 5,
  "main": "index.html",
  "host": [
    {
      "app": "ILST",
      "minVersion": "26.0"
    }
  ],
  "entrypoints": [
    {
      "type": "panel",
      "id": "designer-helper-panel",
      "label": {
        "default": "시안 도우미"
      },
      "minimumSize": { "width": 320, "height": 480 },
      "maximumSize": { "width": 800, "height": 2000 },
      "preferredDockedSize": { "width": 380, "height": 720 },
      "preferredFloatingSize": { "width": 480, "height": 800 },
      "icons": [
        { "width": 23, "height": 23, "path": "icons/dark.png", "scale": [1, 2], "theme": ["darkest", "dark", "medium"] },
        { "width": 23, "height": 23, "path": "icons/light.png", "scale": [1, 2], "theme": ["lightest", "light"] }
      ]
    }
  ],
  "icons": [
    { "width": 48, "height": 48, "path": "icons/plugin.png", "scale": [1, 2] }
  ],
  "requiredPermissions": {
    "localFileSystem": "fullAccess",
    "network": {
      "domains": ["http://192.168.0.133:3000"]
    }
  }
}
