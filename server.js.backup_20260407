    // 발송 기록 저장
    if (quoteId) {
      if (db.sql) {
        const quote = db.sql.quotes.getById(quoteId);
        if (quote) {
          if (!quote.mailHistory) quote.mailHistory = [];
          const cookies = parseCookies(req);
