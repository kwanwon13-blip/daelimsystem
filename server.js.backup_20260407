// GET  /api/attendance/notes        → 전체 노트 반환
// PUT  /api/attendance/notes/:key   → 노트 저장 (key = "이름_YYYY-MM-DD")
// DELETE /api/attendance/notes/:key → 노트 삭제 (자동 분류로 복원)
// ─────────────────────────────────────────────────────────
app.get('/api/attendance/notes', requireAuth, (req, res) => {
