# ══════════════════════════════════════════════════════════════
# .env.example — 환경변수 템플릿 (git에 포함됨)
# ══════════════════════════════════════════════════════════════
#
# 사용 방법:
#   1. 이 파일을 `.env` 로 복사
#        cp .env.example .env
#   2. 아래 값들을 자기 환경에 맞게 수정 (비밀번호는 실제 값으로)
#   3. `.env` 는 .gitignore 에 등록돼 있어서 git 에 올라가지 않음
#
# PC 별 배포:
#   - 로컬 PC (192.168.0.30): SALARY_DAEMON_* 값이 중요
#   - 서버 PC (192.168.0.133): SALARY_* 프록시 값 + CONTROL_DAEMON_* 중요
#   - 공통 값은 양쪽 모두 동일하게
#
# 시크릿 생성 방법 (64자 16진수):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# ══════════════════════════════════════════════════════════════


# ── 메인 서버 (server.js) ────────────────────────────────────
# 웹 서버 포트 (브라우저가 접속하는 포트)
PORT=3000

# 급여 모드: local = 같은 PC DB 직결 / proxy = 로컬 PC 데몬 호출
# 서버 PC에서는 반드시 proxy, 단일 개발 환경에서는 local
SALARY_MODE=local


# ── 급여 데몬 (salary-daemon.js, 로컬 PC 전용) ─────────────────
# salary-daemon 이 바인딩할 포트
SALARY_DAEMON_PORT=3001

# 바인딩 주소 (0.0.0.0 = 모든 네트워크 인터페이스, 127.0.0.1 = 로컬만)
SALARY_DAEMON_BIND=0.0.0.0

# 서버 PC 와 공유하는 비밀 시크릿 (64자 16진수) — 반드시 변경하고 양쪽 동일하게
SALARY_DAEMON_SECRET=CHANGE_ME_64hex

# 서버 PC IP (급여 데몬이 서버 PC 만 허용하도록 검증)
SALARY_SERVER_IP=192.168.0.133


# ── 급여 프록시 (routes/salary-proxy.js, 서버 PC 전용) ─────────
# 로컬 PC (급여 데몬) IP — 서버 PC 는 여기로만 요청 허용
SALARY_SOURCE_IP=192.168.0.30

# 로컬 PC 급여 데몬 주소 (salary-daemon 은 3002 — 3001 은 CAPS Bridge 전용)
SALARY_DAEMON_URL=http://192.168.0.30:3002

# 급여 데몬 호출 타임아웃 (ms)
SALARY_DAEMON_TIMEOUT=15000


# ── 원격 제어 데몬 (control-daemon.js, 서버 PC 전용) ───────────
# control-daemon 이 바인딩할 포트
CONTROL_DAEMON_PORT=3002

# 바인딩 주소
CONTROL_DAEMON_BIND=0.0.0.0

# 로컬 PC 원격 제어 HTML 과 공유하는 비밀 시크릿 (64자 16진수)
CONTROL_DAEMON_SECRET=CHANGE_ME_64hex

# 메인 서버가 설치된 폴더 (비우면 control-daemon.js 가 있는 폴더와 동일)
CONTROL_APP_DIR=


# ── 시안 검색 (routes/design.js) ────────────────────────────
# 시안 이미지 검색 루트 디렉토리 (서버 PC 경로)
DESIGN_ROOT=D:\


# ── Kakao 로컬 API (routes/gps-attendance.js, 선택) ───────────
# 근태 GPS → 주소 변환에 사용 (없으면 대체 API 사용)
KAKAO_REST_KEY=


# ── GitHub Webhook (routes/misc.js, 선택) ────────────────────
# GitHub 에서 푸시 이벤트로 자동 배포할 때 사용
GITHUB_WEBHOOK_SECRET=


# ══════════════════════════════════════════════════════════════
# ── Claude API (routes/ai-history.js) ───────────────────────
# ══════════════════════════════════════════════════════════════
# 있으면 Claude API 모드 (권장), 없으면 Claude CLI 로 fallback
# 발급: https://console.anthropic.com → API Keys → Create Key
# 키 형식: sk-ant-api03-xxxxxxxx...
ANTHROPIC_API_KEY=

# 기본 사용 모델 (생략 가능, 기본값 claude-sonnet-4-6)
#   claude-haiku-4-5-20251001  : 가장 싸고 빠름 (간단 대화)
#   claude-sonnet-4-6          : 균형 (일반 문서·분석, 기본값)
#   claude-opus-4-6            : 가장 강력 (복잡 추론, 비쌈)
ANTHROPIC_MODEL=claude-sonnet-4-6

# 응답 최대 토큰 수 (생략 가능, 기본 2048)
ANTHROPIC_MAX_TOKENS=2048
